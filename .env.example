# Copy to .env and fill in. NEVER commit .env.
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Postgres (matches docker-compose.yml defaults for local dev)
DATABASE_URL=postgresql://app:app@localhost:5432/app?schema=public

# Auth — generate strong random values, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# monday.com integration (leave blank to disable outside production)
MONDAY_API_TOKEN=
MONDAY_SIGNING_SECRET=
MONDAY_DEALS_BOARD_ID=

# QuickBooks Online — credentials come from HERE only, never source.
# Get client id/secret from the Intuit developer portal. Set all four (or none).
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=https://app.example.com/integrations/quickbooks/callback
# 'sandbox' or 'production'. Start with sandbox.
QBO_ENVIRONMENT=sandbox
# 32+ char secret used to encrypt stored OAuth tokens, e.g. `openssl rand -hex 32`
QBO_TOKEN_ENC_KEY=
# HARD SAFETY GATE — live writes to the PRODUCTION company are refused unless
# this is 'true'. Keep 'false' until the production test plan is authorized.
QBO_PRODUCTION_WRITE_ENABLED=false
